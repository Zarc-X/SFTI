<view class="bg-stars"></view>
<view class="container q-container" wx:if="{{currentQuestion}}">
  <view class="progress-bar">{{currentIndex + 1}} / {{totalQuestions}}</view>
  <view class="q-card">
    <view class="q-title">{{currentQuestion.q}}</view>
    <view class="options-list">
      <view class="option-item" wx:for="{{currentQuestion.options}}" wx:key="index" bindtap="selectOption" data-val="{{item.value}}">
        <text>{{item.text}}</text>
      </view>
    </view>
  </view>
  <view class="bottom-action">
    <button class="back-btn" wx:if="{{currentIndex > 0}}" bindtap="goBack">上一题</button>
  </view>
</view>