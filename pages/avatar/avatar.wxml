<view class="bg-stars"></view>
<view class="container img-container">
  <view class="title">身份档案卡</view>
  
  <view class="avatar-card" id="avatar-card">
    <view class="preview-box" bindtap="chooseImage">
      <image wx:if="{{uploadImageUrl && !generatedImageUrl}}" src="{{uploadImageUrl}}" mode="aspectFill"></image>
      <image wx:elif="{{generatedImageUrl}}" src="{{generatedImageUrl}}" mode="aspectFill"></image>
      <view wx:else class="upload-tips"><text class="plus">+</text><text>点击上传照片作为参考(可选)</text></view>
    </view>
    
    <view class="card-info" wx:if="{{generatedImageUrl}}">
      <view class="card-name">{{personalityName}}</view>
      <view class="card-traits">
        <text class="trait-tag" wx:for="{{traits}}" wx:key="*this">{{item}}</text>
      </view>
      <view class="card-short">“{{personalityShort}}”</view>
    </view>
  </view>

  <view class="btn-group">
    <button class="generate-btn" bindtap="handleGenerateImage" wx:if="{{!generatedImageUrl}}" disabled="{{isGenerating}}">{{isGenerating ? '正在建立空间连接...' : '开始生成科幻形象'}}</button>
    <button class="save-btn" bindtap="saveToAlbum" wx:if="{{generatedImageUrl}}">保存视觉档案</button>
    <button class="retry-btn" bindtap="handleGenerateImage" wx:if="{{generatedImageUrl}}" disabled="{{isGenerating}}">重新生成档案</button>
  </view>
</view>