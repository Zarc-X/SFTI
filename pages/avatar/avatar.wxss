.img-container { padding: 40rpx; }
.title { font-size: 40rpx; font-weight: bold; color: #00F0FF; margin-bottom: 20rpx; letter-spacing: 2rpx; text-shadow: 0 0 10rpx rgba(0, 240, 255, 0.5); }

/* 档案卡样式 */
.avatar-card {
  width: 600rpx;
  background: rgba(11, 15, 31, 0.8);
  border: 2rpx solid rgba(0, 240, 255, 0.3);
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 40rpx;
  box-shadow: 0 0 30rpx rgba(0, 240, 255, 0.1);
}

.preview-box { 
  width: 100%; 
  height: 600rpx; 
  display: flex; 
  justify-content: center; 
  align-items: center; 
  background: rgba(0, 240, 255, 0.02); 
  overflow: hidden;
}

.preview-box image { width: 100%; height: 100%; }
.upload-tips { display: flex; flex-direction: column; align-items: center; color: rgba(0,240,255,0.5); font-size: 28rpx; }
.plus { font-size: 80rpx; margin-bottom: 10rpx; font-weight: 200; }

/* 生成成功后的卡片信息 */
.card-info {
  padding: 40rpx 30rpx;
  background: linear-gradient(180deg, rgba(0, 240, 255, 0.05) 0%, rgba(0, 240, 255, 0.15) 100%);
  border-top: 2rpx solid rgba(0, 240, 255, 0.2);
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}
.card-info::before {
  content: '';
  position: absolute;
  top: 0; left: 50%;
  transform: translateX(-50%);
  width: 100rpx;
  height: 4rpx;
  background: #00F0FF;
  box-shadow: 0 0 10rpx #00F0FF;
}

.card-name { font-size: 40rpx; font-weight: bold; color: #00F0FF; margin-bottom: 24rpx; text-shadow: 0 0 12rpx rgba(0,240,255,0.6); letter-spacing: 4rpx; }

.card-traits {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.trait-tag {
  background: rgba(0, 240, 255, 0.1);
  border: 1rpx solid rgba(0, 240, 255, 0.4);
  color: #fff;
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  letter-spacing: 2rpx;
}

.card-short { 
  font-size: 28rpx; 
  color: #ddd; 
  line-height: 1.6; 
  text-align: center;
  font-style: italic;
}

.btn-group { width: 100%; margin-top: 15rpx; }
button { width: 100%; height: 90rpx; line-height: 90rpx; border-radius: 45rpx; font-size: 32rpx; margin-bottom: 25rpx; }
.generate-btn { background: #00F0FF; color: #0B0F1F; font-weight: bold; box-shadow: 0 0 20rpx rgba(0,240,255,0.4); }
.generate-btn[disabled] { background: #555; color: #999; box-shadow: none; }
.save-btn { background: #00F0FF; color: #0B0F1F; font-weight: bold; }
.retry-btn { background: transparent; color: #fff; border: 1rpx solid rgba(255,255,255,0.3); }