.img-container { padding: 60rpx 40rpx; }
.title { font-size: 40rpx; font-weight: bold; color: #00F0FF; margin-bottom: 60rpx; }
.preview-box { width: 500rpx; height: 650rpx; border: 2rpx dashed #00F0FF; border-radius: 20rpx; display: flex; justify-content: center; align-items: center; background: rgba(0, 240, 255, 0.05); overflow: hidden; margin-bottom: 80rpx; }
.preview-box image { width: 100%; height: 100%; }
.upload-tips { display: flex; flex-direction: column; align-items: center; color: rgba(0,240,255,0.5); }
.plus { font-size: 80rpx; margin-bottom: 10rpx; }
.btn-group { width: 100%; }
button { width: 100%; height: 90rpx; line-height: 90rpx; border-radius: 45rpx; font-size: 32rpx; margin-bottom: 30rpx; }
.generate-btn { background: #00F0FF; color: #0B0F1F; font-weight: bold; box-shadow: 0 0 20rpx rgba(0,240,255,0.4); }
.generate-btn[disabled] { background: #555; color: #999; box-shadow: none; }
.save-btn { background: #00F0FF; color: #0B0F1F; font-weight: bold; }
.retry-btn { background: transparent; color: #fff; border: 1rpx solid rgba(255,255,255,0.3); }