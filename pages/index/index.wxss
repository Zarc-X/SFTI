.index-container { justify-content: center; }
.title-space { display: flex; flex-direction: column; align-items: center; margin-bottom: 40rpx; }
.title { font-size: 100rpx; font-weight: bold; color: #00F0FF; text-shadow: 0 0 20rpx rgba(0,240,255,0.6); letter-spacing: 10rpx; }
.subtitle { font-size: 40rpx; color: #FFFFFF; margin-top: 20rpx; letter-spacing: 5rpx; }
.desc-space { margin-bottom: 150rpx; color: rgba(255,255,255,0.7); font-size: 28rpx; }
.start-btn { width: 500rpx; height: 100rpx; background: linear-gradient(90deg, #1A0F2A, #0B0F1F, #00F0FF); border: 2rpx solid #00F0FF; border-radius: 50rpx; color: #FFFFFF; font-size: 36rpx; line-height: 100rpx; box-shadow: 0 0 30rpx rgba(0,240,255,0.3); transition: all 0.3s; }
.start-btn:active { transform: scale(0.95); box-shadow: 0 0 10rpx rgba(0,240,255,0.8); }